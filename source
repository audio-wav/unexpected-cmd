local function updateList(filter)
	filter = string.lower(filter or "")
	local all, filtered = {}, {}
	for _, c in ipairs(unexpected_UI["BTNLIST"]:GetChildren()) do
		if c:IsA("TextButton") then table.insert(all, c) end
	end
	if filter == "" then
		for i, btn in ipairs(all) do
			btn.Visible = true
			btn.Position = UDim2.new(0, 0, 0, (i - 1) * 32)
		end
		unexpected_UI.BTNLIST.CanvasSize = UDim2.new(0, 0, 0, #all * 32)
		return
	end
	for _, btn in ipairs(all) do
		if _btnMeta[btn] and _btnMeta[btn].data then
			local cmd = _btnMeta[btn].data
			if cmd._lowerOriginal:find(filter, 1, true) or
				(cmd._lowerAliases and (function()
					for _, alias in ipairs(cmd._lowerAliases) do
						if alias:find(filter, 1, true) then return true end
					end
					return false
				end)()) then
				table.insert(filtered, btn)
			end
		end
	end
	table.sort(filtered, function(a, b)
		local cmdA = _btnMeta[a] and _btnMeta[a].data
		local cmdB = _btnMeta[b] and _btnMeta[b].data
		if not cmdA or not cmdB then return a.Text < b.Text end
		local posA = cmdA._lowerOriginal:find(filter, 1, true) or (function()
			for _, alias in ipairs(cmdA._lowerAliases) do
				local p = alias:find(filter, 1, true) if p then return p end
			end
			return math.huge
		end)()
		local posB = cmdB._lowerOriginal:find(filter, 1, true) or (function()
			for _, alias in ipairs(cmdB._lowerAliases) do
				local p = alias:find(filter, 1, true) if p then return p end
			end
			return math.huge
		end)()
		if posA ~= posB then return posA < posB end
		return cmdA._lowerOriginal < cmdB._lowerOriginal
	end)
	for i, btn in ipairs(filtered) do
		btn.Position = UDim2.new(0, 0, 0, (i - 1) * 32)
		btn.Visible = true
	end
	for _, btn in ipairs(all) do btn.Visible = table.find(filtered, btn) ~= nil end
	unexpected_UI.BTNLIST.CanvasSize = UDim2.new(0, 0, 0, #filtered * 32)
