local function GetCustomAsset(AssetName: string): string
	if not uxgetcustomasset then return Settings.Theme.Assets[AssetName] end
	local Success, AssetId = pcall(uxgetcustomasset, AssetName)
	return (Success and AssetId ~= "" and AssetId) or Settings.Theme.Assets[AssetName]
end

