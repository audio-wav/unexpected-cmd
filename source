	local frame = MENUFRAMES[tabKey]
	if not frame then return end
	for _, f in next, MENUFRAMES do if f ~= frame and f.Visible then fadeOut(f) end end
	for _, b in next, MENUS do b.Visible = false end
	UnexpectedUi.Label.Text = tabKey
	local info = UnexpectedUi.InfoFrame

	if CreateTween then
		local t = CreateTween(info, {
