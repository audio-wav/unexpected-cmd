do
    local function caseSens(pattern, word)
		local out = {}
		for i = 1, #word do
			local c = word:sub(i,i)
			local p = pattern:sub(i,i)
			-- use a better method instead of nesting
			out[i] = (p ~= "" and p:match("%u")) and c:upper() or c:lower()
		end
		return table.concat(out)
	end

    local CommandLine, Predictor = UnexpectedUi.CommandLine, UnexpectedUi.Predictor
    -- LOG H3
    CommandLine:GetPropertyChangedSignal("Text"):Connect(function()
       	local _showReco = IsMobile and not MENUON
        local Input = CommandLine.Text:gsub("%s+$", "")
        local CommandName, ArgText = Input:match("^(%S+)%s(.*)$")
        local BareCommand = Input:match("^(%S+)$") or ""
        local Suggestion = ""
        if BareCommand ~= "" then
            local LowerCommand = string.lower(BareCommand)
            local Matches = {}
            local AllMatches = {}
            
            for Name in next, CommandListData do
                local LowerName = string.lower(Name)
                if string.sub(LowerName, 1, #LowerCommand) == LowerCommand then
                    table.insert(Matches, Name)
                    table.insert(AllMatches, {key = Name, prio = 1})
                elseif string.find(LowerName, LowerCommand, 1, true) then
                    table.insert(AllMatches, {key = Name, prio = 2})
                end
            end
            
            table.sort(Matches)
            if #Matches > 0 then
                local bestKey = Matches[1]
                Suggestion = if string.lower(bestKey) == LowerCommand then ""
                    else `{Input}{string.sub(bestKey, #BareCommand + 1)}`
            end

            for _, c in next, UnexpectedUi.RecoFrame:GetChildren() do
                if c:IsA("GuiButton") then c:Destroy() end
            end
            
            table.sort(AllMatches, function(a, b)
                if a.prio ~= b.prio then return a.prio < b.prio end
                return a.key < b.key
            end)

            if #AllMatches > 0 then
                local YOffset = 0
                for i = 1, math.min(#AllMatches, 8) do
                    local Data = AllMatches[i]
                    local Match = Data.key
                    local Btn = make("TextButton", UnexpectedUi.RecoFrame, {
                        Size = UDim2.new(1, 0, 0, 30), Position = UDim2.new(0, 0, 0, YOffset),
                        BackgroundTransparency = 1, Text = Match, TextColor3 = UiQuery.COLORS.TEXT_MAIN,
                        FontFace = UiQuery.FONTS.REGULAR, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left,
                        Name = `RecoBtn_{i}`
                    })
                    make("UIPadding", Btn, { PaddingLeft = UDim.new(0, 8) })
                    Btn.MouseButton1Click:Connect(function()
                        CommandLine.Text = `{Match} `
                        CommandLine:CaptureFocus()
                    end)
                    YOffset += 30
                end
                local MaxH = 120
                UnexpectedUi.RecoFrame.Size = UDim2.new(0, 210, 0, math.min(YOffset, MaxH))
                UnexpectedUi.RecoFrame.CanvasSize = UDim2.new(0, 0, 0, YOffset)
                UnexpectedUi.RecoFrame.Visible = _showReco
            else
                UnexpectedUi.RecoFrame.Visible = false
            end
        else
            UnexpectedUi.RecoFrame.Visible = false
            if CommandName and ArgText then
                local Command = CommandListData[string.lower(CommandName)]
                if Command and Command.UsageArgs and #Command.UsageArgs > 0 then
                    local HasPlayerArgument = false
                    for _, Arg in next, Command.UsageArgs do
                        local LowerArg = string.lower(Arg)
                        if LowerArg ~= "player" and LowerArg ~= "plr" then continue end
                        HasPlayerArgument = true
                        break
                    end
                    
                    if HasPlayerArgument then
                        local LastArg = (string.match(ArgText, "%S+$") or ""):gsub("%s+$", "")
                        local LowerArg = string.lower(LastArg)
                        local BestMatch = nil
                        for _, Player in next, Players:GetPlayers() do
                            if Player == LocalPlayer then continue end
                            local Name, DisplayName = Player.Name, Player.DisplayName
                            local LowerName, LowerDisplayName = string.lower(Name), string.lower(DisplayName)
                            local Candidate
                            if LowerArg == "" or LowerName:sub(1, #LowerArg) == LowerArg then
                                Candidate = Name
                            elseif LowerDisplayName:sub(1, #LowerArg) == LowerArg then
                                Candidate = DisplayName
                            end
                            if Candidate and (not BestMatch or string.lower(Candidate) < string.lower(BestMatch)) then
                                BestMatch = Candidate
                            end
                        end
                        if BestMatch then
                            local PrefixArgs = (ArgText or ""):match("^(.-)%S+$") or ""
                            local Formatted = caseSens(LastArg, BestMatch)
                            Suggestion = if LowerArg == string.lower(BestMatch) then ""
                                else `{CommandName} {PrefixArgs}{Formatted}`
                        end
                    end
                end
            end
        end
        Predictor.Text = Suggestion
    end)

    CommandLine.FocusLost:Connect(function(EnterPressed)
        UnexpectedUi.RecoFrame.Visible = false
        if not EnterPressed then return end

        local Input = CommandLine.Text
        local CommandName, ArgText = Input:match("^(%S+)%s*(.*)$")
        if not CommandName then return end

        local Command = CommandListData[string.lower(CommandName)]
        if Command and ArgText then
            local Args = {}
            for Arg in string.gmatch(ArgText, "%S+") do
                Args[#Args + 1] = Arg
            end
            Command.Execute(table.unpack(Args))
        end

        CommandLine.Text = ""
        Predictor.Text = ""
    end)

    local Suppress = false
    CommandLine:GetPropertyChangedSignal("Text"):Connect(function()
        if Suppress then return end

        local CLIText = CommandLine.Text
        if not CLIText:find("	") then return end

        Suppress = true
        local Suggestion = Predictor.Text
        if Suggestion ~= "" then
            CommandLine.Text = Suggestion
            Predictor.Text = ""
        else
            CommandLine.Text = CLIText:gsub("	", "")
        end

        CommandLine.CursorPosition = #CLIText + 1
        Suppress = false
    end)
end

local function updateList(filter: string)
	filter = string.lower(filter or "")
	local all, filtered = {}, {}
	for _, c in next, UnexpectedUi["BTNLIST"]:GetChildren() do
		if c:IsA("TextButton") then table.insert(all, c) end
	end
	if filter == "" then
		for i, btn in next, all do
			btn.Visible = true
			btn.Position = UDim2.new(0, 0, 0, (i - 1) * 32)
		end
		UnexpectedUi.BTNLIST.CanvasSize = UDim2.new(0, 0, 0, #all * 32)
		return
	end
	for _, btn in next, all do
		if _btnMeta[btn] and _btnMeta[btn].data then
			local cmd = _btnMeta[btn].data
			if cmd._lowerOriginal:find(filter, 1, true) or
				(cmd._lowerAliases and (function()
					for _, alias in next, cmd._lowerAliases do
						if alias:find(filter, 1, true) then return true end
					end
					return false
				end)()) then
				table.insert(filtered, btn)
			end
		end
	end
	table.sort(filtered, function(a, b)
		local cmdA = _btnMeta[a] and _btnMeta[a].data
		local cmdB = _btnMeta[b] and _btnMeta[b].data
		if not cmdA or not cmdB then return a.Text < b.Text end
		local posA = cmdA._lowerOriginal:find(filter, 1, true) or (function()
			for _, alias in next, cmdA._lowerAliases do
				local p = alias:find(filter, 1, true)
                if p then return p end
			end
			return math.huge
		end)()
		local posB = cmdB._lowerOriginal:find(filter, 1, true) or (function()
			for _, alias in next, cmdB._lowerAliases do
				local p = alias:find(filter, 1, true)
                if p then return p end
			end
			return math.huge
		end)()
		if posA ~= posB then return posA < posB end
		return cmdA._lowerOriginal < cmdB._lowerOriginal
	end)
	for i, btn in next, filtered do
		btn.Position = UDim2.new(0, 0, 0, (i - 1) * 32)
		btn.Visible = true
	end
	for _, btn in next, all do btn.Visible = table.find(filtered, btn) ~= nil end
	UnexpectedUi.BTNLIST.CanvasSize = UDim2.new(0, 0, 0, #filtered * 32)
end

