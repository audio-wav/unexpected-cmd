actionBtn.MouseButton1Click:Connect(function()
	local item = currentStoreItem
	if not item then return end
	if item.got then
		local name = item.name
		pcall(function() if removePlugin then removePlugin({name = name}) end end)
		pcall(delfile, name .. ".iy")
		pcall(delfile, "unexpected_plugins/" .. name .. ".iy")
		_installedPlugins[name] = nil
		item.got = false
		_storeProcessed = {}
		if List.renderers.store then pcall(List.renderers.store) end
		actionBtn.Text = "install"
		return
	end

	task.spawn(function()
		local okALL = false
		for _, f in ipairs(item.p.files or {}) do
			if f.filename:match("%.iy$") then
				local url = HS:UrlEncode("https://iyplugins.pages.dev/" .. f.url)
				local tracker = "https://iy-analytics.renern.workers.dev/load/"
					.. item.p.id .. "?url=" .. url
				local ok, src = pcall(game.HttpGet, game, tracker)
				if ok and src then
					pcall(writefile, f.filename, src)
					pcall(writefile, "unexpected_plugins/" .. f.filename, src)
					okALL = true
				end
			end
		end

		if not okALL then 
			if currentStoreItem == item then actionBtn.Text = "install" end 
			return
		end

		_installedPlugins[item.name] = true
		item.got = true
		if addPlugin then pcall(addPlugin, {item.name}) end
		_storeProcessed = {}
		if List.renderers.store then pcall(List.renderers.store) end
		if currentStoreItem == item then
			actionBtn.Text = "delete"
		end
	end)
end)

