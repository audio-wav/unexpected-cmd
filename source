local UiCornerTable: {{UICorner: UICorner, OriginalRadius: UDim}} = {}
local function CreateCorner(
    Parent: Instance?,
    RadiusScale: number?,
    RadiusOffset: number?
): UICorner
    local _RadiusScale = RadiusScale or 0
    local _RadiusOffset = RadiusOffset or 0

	local Corner = Create("UICorner", Parent, {
        CornerRadius = UDim.new(_RadiusScale, _RadiusOffset)
    })

	UiCornerTable[#UiCornerTable + 1] = {UICorner = Corner, OriginalRadius = UDim.new(_RadiusScale, _RadiusOffset)}

	return Corner
end

