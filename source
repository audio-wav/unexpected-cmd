local function AddPlugin(args)
	local NAME = args.name or args[1]
	if not NAME or NAME == "" then
        Unexpected:Notify("unexpected", "Usage: plugin [name]")
        return
    end
	if LoadPlugin(NAME) then
		Settings.Plugins[NAME] = true
		SaveSettings()
		if MenuFrames.plugin.Visible then RenderList("plugin") end
		if MenuFrames.command.Visible then
			ClearCommandList()
			ShowCommandList()
		end
	end
end

local function StripPluginCommands(pluginName)
	local newArray = {}
	for _, entry in next, CommandListArray do
		if entry._pluginTag ~= pluginName then
			table.insert(newArray, entry)
		else
			CommandListData[entry._lowerOriginal] = nil
			for _, alias in next, entry._lowerAliases do
				CommandListData[alias] = nil
			end
		end
	end
	CommandListArray = newArray
end

local function RemovePlugin(args)
	local NAME = args.name or args[1]
	if not NAME or NAME == "" then
        Unexpected:Notify("unexpected", "Usage: unplugin [name]")
        return
    end
	if Settings.Plugins[NAME] then
		Settings.Plugins[NAME] = nil
		StripPluginCommands(NAME)
		SaveSettings()
		Unexpected:Notify("unexpected", "Plugin '" .. NAME .. "' disabled.")
		if MenuFrames.plugin.Visible then RenderList("plugin") end
		if MenuFrames.command.Visible then
			ClearCommandList()
			ShowCommandList()
		end
	else
		Unexpected:Notify("unexpected", "Plugin '" .. NAME .. "' is not enabled.")
	end
end

local function HookBinds()
	for _, Connection in next, BindConnections do
        Connection:Disconnect()
    end
	BindConnections = {}
	BindToggleStates = {}
	Keybinds = {}
	Settings.Binds = Settings.Binds or {}
	for _, Bind in next, Settings.Binds do
		if Bind.isPlugin then
			Unexpected:Notify("unexpected", "Note: Plugin Binds require Plugins to be reloaded to restore.")
		else
			UX_AddBind(Bind.key, Bind.cmd, Bind.toggle)
		end
	end
end

