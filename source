		}, 0.25, Enum.EasingStyle.Quint)
		t:Play()
		t.Completed:Once(function()
			info.Visible = false
		end)
	else
		game:GetService("TweenService"):Create(
			info,
			TweenInfo.new(0.25, Enum.EasingStyle.Quint),
			{ Size = UDim2.new(0, 0, 0, 0) }
