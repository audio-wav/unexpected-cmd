local function UpdateNotificationQueue(): ()
	NotifSequence += 1
	local Sequence = NotifSequence
	local Queue = NotifQueue
	if #Queue == 0 then
		NotificationFadeOut()
		return
	end
	IsNotifActive = true
	local Total = #Queue
	local Data = assert(table.remove(Queue, 1))
	NotifTitleUi.Text = Data.title .. " (" .. Total .. ")"
	NotifTextUi.Text = Data.text
	LoadingBarUi.Size = UDim2.new(0.82, 0, 0, 1)
	NotifUi.Visible = true
	if Total == 1 then
		local Query = NotifUi:QueryDescendants("TextLabel,TextButton")
		NotifUi.BackgroundTransparency = 1
		for _, v in next, Query do
            v.TextTransparency = 1
        end
		CreateTween(NotifUi, {BackgroundTransparency = 0,Position = NotifPosition}, 0.25):Play()
		for i = 1, #Query do
            CreateTween(Query[i], { TextTransparency = 0 }, 0.25):Play()
        end
	end
	local t = ActiveBarTween
	if t then t:Cancel() end
	t = CreateTween(LoadingBarUi,{ Size = UDim2.new(0, 0, 0, 1) },5,Enum.EasingStyle.Linear)
	ActiveBarTween = t
	t:Play()
	task.delay(5, function()
		if Sequence == NotifSequence then UpdateNotificationQueue() end
	end)
end

