Unexpected:AddCommand("importiy", "Import plugins, binds, and events from Infinite Yield", function()
    if not isfile("IY_FE.iy") then
		Unexpected:notify("importiy", "IY_FE.iy not found.")
		return
	end
    local ok, parsed = pcall(function() return HttpService:JSONDecode(readfile("IY_FE.iy")) end)
    if not ok or type(parsed) ~= "table" then
		Unexpected:notify("importiy", "Failed to parse IY_FE.iy")
		return
	end
    local imported = { plugins = 0, binds = 0, events = 0 }
    CONFIG.Plugins, CONFIG.Binds, CONFIG.Events, CONFIG.Autoruns =
        CONFIG.Plugins or {}, CONFIG.Binds or {}, CONFIG.Events or {}, CONFIG.Autoruns or {}
    for _, pluginFile in next, parsed.PluginsTable or {} do
        local name = tostring(pluginFile):match("^(.+)%.[^.]+$") or tostring(pluginFile)
        if not CONFIG.Plugins[name] then
            if LOAD_PLUGIN(name) then
                CONFIG.Plugins[name] = true
                imported.plugins += 1
            end
        end
    end
	for _, bd in next, parsed.binds or {} do
		local key = tostring(bd.KEY or ""):match("Enum%.KeyCode%.(.+)$") or bd.KEY
		local cmd = bd.COMMAND
		local toggleCmd = bd.TOGGLE
		if key and cmd then
			local isToggle = toggleCmd ~= nil and toggleCmd ~= ""
			local bindId = mkBINDID()
			table.insert(CONFIG.Binds, { id = bindId, key = key:lower(), cmd = cmd, toggle = isToggle, isPlugin = false })
			UX_addbind(key, cmd, isToggle)
			imported.binds += 1
		end
	end
    local IY_TO_UX = {OnSpawn="respawned", OnDied="died", OnKilled="died", OnJoin="playerjoined", OnLeave="playerleft", OnDamage="healthchanged", OnChatted="chatted"}
    local evOk, evData = pcall(function() return HttpService:JSONDecode(parsed.eventBinds or "{}") end)
    if evOk and type(evData) == "table" then
        for iyEvent, entries in next, evData do
            for _, entry in next, type(entries) == "table" and entries or {} do
                local cmd = entry[1]
                if cmd and tostring(cmd) ~= "" then
                    if iyEvent == "OnExecute" then
                        if not table.find(CONFIG.Autoruns, tostring(cmd)) then
                            table.insert(CONFIG.Autoruns, tostring(cmd))
                            imported.events += 1
                        end
                    elseif IY_TO_UX[iyEvent] then
                        table.insert(CONFIG.Events, { event = IY_TO_UX[iyEvent], filter = nil, cmd = tostring(cmd) })
                        imported.events += 1
                    end
                end
            end
        end
        hookEvents()
    end
    UX_config()
    for _, pair in next, {{"autorun","autorun"},{"plugin","plugin"},{"bind","bind"},{"event","event"}} do if MENUFRAMES[pair[1]].Visible then renderList(pair[2]) end end
    Unexpected:notify("importiy", ("Imported: %d plugin(s), %d bind(s), %d event(s)."):format(imported.plugins, imported.binds, imported.events))
end)

