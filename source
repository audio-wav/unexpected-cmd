local function lc()
	local config = {}
	if isfile(configFile) then
		local success, content = pcall(readfile, configFile)
		if success and content then
			local ok, parsed = pcall(function() return HttpService:JSONDecode(content) end)
			if ok and typeof(parsed) == "table" then config = parsed end
		end
	end
	for key, default in pairs(defaultConfig) do
