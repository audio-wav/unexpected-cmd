local function SetActiveTab(tabKey: string?, onOpen): ()
	local frame = MenuFrames[tabKey]
	if not frame then return end
	for _, f in next, MenuFrames do if f ~= frame and f.Visible then FadeOut(f) end end
	for _, b in next, MenuButtons do b.Visible = false end
	UnexpectedUi.Label.Text = tabKey
	local info = UnexpectedUi.InfoFrame

	if CreateTween then
		local t = CreateTween(info, {
			Size = UDim2.new(0, 0, 0, 0)
		}, 0.25, Enum.EasingStyle.Quint)
		t:Play()
		t.Completed:Once(function()
			info.Visible = false
		end)
	else
		game:GetService("TweenService"):Create(
			info,
			TweenInfo.new(0.25, Enum.EasingStyle.Quint),
			{ Size = UDim2.new(0, 0, 0, 0) }
		):Play()
		task.delay(0.25, function()
			info.Visible = false
		end)
	end

	currentStoreItem = nil
	local function open(): ()
		if onOpen then
			local Success, Error = pcall(onOpen)
			if not Success then warn("onOpen error:", Error) end
		end
		FadeIn(frame)
	end

	if Settings.MenuOn then
        open()
        return
    end

	Settings.MenuOn = true
	MenuFrame.Visible = true
	CreateTween(UnexpectedUi.PILL, {Size = UDim2.new(0,339,0,71)}, 0.25, Enum.EasingStyle.Quint):Play()
	CreateTween(Cli, {Size = UDim2.new(0,230,0,54)}, 0.25, Enum.EasingStyle.Quint):Play()
	CreateTween(UnexpectedUi.Predictor, {Size = UDim2.new(0,230,0,54)}, 0.25, Enum.EasingStyle.Quint):Play()
	CreateTween(MenuFrame, {Size = UDim2.new(0,339,0,348)}, 0.25, Enum.EasingStyle.Quint):Play()
	ButtonTween(Menu, 0)
	task.delay(0.25, open)
