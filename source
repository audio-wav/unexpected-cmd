local function ApplyTheme(): ()
	local background, stroke, textMain, textDim, accent =
        Settings.Theme.Background,
        Settings.Theme.Stroke,
        Settings.Theme.TextMain,
        Settings.Theme.TextDim,
        Settings.Theme.Accent
	if _sharedTooltip then
		_sharedTooltip.BackgroundColor3 = background
		_sharedTooltip.TextColor3 = textMain
		for _, s in next, _sharedTooltip:GetChildren() do
			if s:IsA("UIStroke") then s.Color = stroke end
		end
	end
	if Indicator then
		Indicator.BackgroundColor3 = background
		for _, s in next, Indicator:GetChildren() do
			if s:IsA("UIStroke") then s.Color = stroke end
		end
	end
	for _, obj in next, UnexpectedUi.UI:GetDescendants() do
		if obj:IsA("UIStroke") then obj.Color = stroke
		elseif obj:IsA("ScrollingFrame") then obj.ScrollBarImageColor3 = accent
		elseif obj:IsA("TextButton") then
			local colorKey = obj:GetAttribute("colorKey")
			if colorKey then
				obj.BackgroundColor3 = Settings.Theme[colorKey] or background
			else
				obj.BackgroundColor3 = background
			end
			if not obj:GetAttribute("skipTheme") then
				obj.TextColor3 = textMain
			end
		elseif obj:IsA("TextLabel") then obj.TextColor3 = textMain
		elseif obj:IsA("TextBox") then
			obj.TextColor3 = textMain
			obj.PlaceholderColor3 = textDim
			if obj.BackgroundTransparency ~= 1 then obj.BackgroundColor3 = background end
		elseif obj:IsA("ImageButton") or obj:IsA("ImageLabel") then obj.ImageColor3 = accent
		elseif obj:IsA("Frame") and obj.BackgroundTransparency ~= 1 and obj.Name ~= "Bar" then
			obj.BackgroundColor3 = background
		end
	end
	UnexpectedUi.Predictor.TextColor3 = textDim
	LoadingBarUi.BackgroundColor3 = accent
end

local function UpdateIndicator(newSize: number?): ()
	IndicatorSize = math.clamp(newSize or 30, 10, 100)
	Indicator.Size = UDim2.new(0, IndicatorSize, 0, IndicatorSize)
	Settings.Ui.IndicatorSize = IndicatorSize
	SaveSettings()
end

local function UpdateUiCorners(newSize: number?): ()
	local UICornersS = math.clamp(newSize or 1, 0, 1)
	for _, data in next, UiCornerTable do
        local OriginalRadius = data.OriginalRadius
		data.UICorner.CornerRadius = UDim.new(OriginalRadius.Scale * UICornersS, OriginalRadius.Offset)
	end
	SaveSettings()
end

local function ApplyScale(): ()
    if Settings.Ui.Scale then
        for key in next, Settings.Scale.Base do
            Settings.Scale.Base[key] = Settings.Ui.Scale
        end
    end

    local function Set(obj, key)
        if not obj then return end
        local scale = Settings.Scale.Base[key]
        if Settings.IsMobile then
            scale = scale * (Settings.Scale.Mobile[key] or 1)
        end
        local existing = obj:FindFirstChildWhichIsA("UIScale")
        if existing then
            existing.Scale = scale
        else
            Create("UIScale", obj, { Scale = scale })
        end
    end

    Set(NotifUi, "NotificationUI")
    Set(UnexpectedUi["PILL"], "PILL")
end

