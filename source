local _storeCache, _storeProcessed, _storeInit = nil, {}, false
local _installedPlugins = {}

local function SafeDecode(str)
	local Success, res = pcall(HttpService.JSONDecode, HttpService, str)
	if Success and res then return res end
	return nil
end

local function FetchRemote()
	local Success, raw = pcall(function()
		if request then
			return request({Url="https://iyplugins.pages.dev/data/Plugins.json"}).Body
        else
			return game:HttpGet("https://iyplugins.pages.dev/data/Plugins.json")
		end
	end)

	if Success and raw then
		return raw
	end

	return nil
end

local function InstalledPluginsScan()
	table.clear(_installedPlugins)
	if listfiles then
		for _, dir in next, {"unexpected_plugins", "."} do
			pcall(function()
				if dir == "unexpected_plugins" and not isfolder("unexpected_plugins") then return end
				for _, f in next, listfiles(dir) do
					local n = f:match("([^/]+)%.iy$")
					if n then _installedPlugins[n] = true end
				end
			end)
		end
	end
end

local function FetchStore()
	local raw = nil
	if isfile and readfile and isfile("unexpected_store_cache.json") then raw = readfile("unexpected_store_cache.json") end
	if not raw then
		raw = FetchRemote()
		if raw and isfile and writefile then
			pcall(function()
				writefile("unexpected_store_cache.json", raw)
			end)
		end
	end

	if not raw then
		_storeCache = {}
		return
	end

	local data = SafeDecode(raw)
	if not (data and data.Plugins) then
		_storeCache = {}
		return
	end

	_storeCache = data.Plugins

	for _, v in next, _storeCache do
		local y,m,d,h,mi,s = (v.date or ""):match("(%d+)-(%d+)-(%d+)T(%d+):(%d+):(%d+)")
		v._t = y and (y*31536000 + m*2592000 + d*86400 + h*3600 + mi*60 + s) or 0
	end

	table.sort(_storeCache, function(a,b)
		return (a._t or 0) > (b._t or 0)
	end)

	InstalledPluginsScan()
end

local function StoreItems_Init()
	if not _storeInit then
		_storeInit = true
		FetchStore()
		task.spawn(function()
			FetchStore()
		end)
	end

	if not _storeCache then return {} end
	_storeProcessed = {}
	for _, p in next, _storeCache do
		local name = p.name or "unknown"
		for _, f in next, p.files or {} do local n = f.filename:match("(.+)%.iy$")
			if n then
                name = n
                break
            end
		end

		_storeProcessed[#_storeProcessed+1] = {
			text = name .. " [" .. (_installedPlugins[name] and "INSTALLED" or "GET") .. "]",
			name = name,
			p = p,
			got = _installedPlugins[name] == true
		}
	end

	return _storeProcessed
end

