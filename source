				usage = ((#entry.UsageArgs > 0) and ("usage: " .. entry.Original .. " [" .. table.concat(entry.UsageArgs, "] [") .. "]")) or ("usage: " .. entry.Original)
			}
			table.insert(commandButtonCache, btn)
			index = index + 1
		end
