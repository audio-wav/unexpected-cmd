	for _, entry in ipairs(commandListArray) do table.insert(sortedCmds, entry) end
	table.sort(sortedCmds, function(a, b)
		local function groupcmd(name)
			name = name:gsub("^%[.-%]%s*", "")
			return name:gsub("^un", ""), name -- again, old code had some weird nesting that i dont understand
		end
		local na, nb = a._lowerOriginal, b._lowerOriginal
		if na == "discord" then return true end
		if nb == "discord" then return false end
		local ga, sa = groupcmd(na)
		local gb, sb = groupcmd(nb)
		if ga ~= gb then return ga < gb end
		return sa < sb
	end)
	for _, entry in ipairs(sortedCmds) do
		if not used[entry] then
			used[entry] = true
			local btn = table.remove(_btnPool)
			if not btn then
				btn = CMDEXAMPLE:Clone()
				btn.MouseEnter:Connect(function()
					local meta = _btnMeta[btn]
					local d = meta and meta.data
					if not d or not _sharedTooltip then return end
