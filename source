local function Create(Class: string, Parent: Instance?, Properties: {[string]: any}?): any
    local Inst: any = Instance.new(Class)
    if Properties then
        for k, v in next, Properties do
            Inst[k] = v
        end
    end
    if Parent then
        Inst.Parent = Parent
    end
    return Inst
end

