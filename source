type Command = {
    Original: string, Description: string, Aliases: {string},
    UsageArgs: {string}, DisplayName: string, _pluginTag: string?,
    _lowerAliases: {string}, _lowerOriginal: string,
    Execute: (...any) -> ()
}

type PendingUNCommand = {
    name: string,
    func: (...any) -> ()
}

local Unexpected = {}
local CommandListData: {[string]: Command} = {}
local CommandListArray: {Command} = {}
local commandButtonCache: {TextButton} = {}
local _sharedTooltip = nil
local _sharedTooltipToken = 0
local _sharedTooltipConn = nil
local _btnPool: {TextButton} = {}
local _btnMeta = setmetatable({} :: {[TextButton]: {data: Command, usage: string}}, { __mode = "k" })
local PendingUNCommands: {PendingUNCommand} = {}
function Unexpected:AddCommand(
    Name: string, Description: string, Function: (...any) -> (),
    Aliases: {string}?, UsageArgs: {string}?, PluginTag: string?
)
	local _Aliases = Aliases or {}
	local _UsageArgs = UsageArgs or {}

	local DisplayName = Name
	local ActualName = Name:gsub("^%[.-%]%s*", "")

    local LowerAliases: {string} = {}
    local LowerOriginal = string.lower(ActualName)

	local entry: Command = {
		Original = ActualName, Description = Description, Aliases = _Aliases,
		UsageArgs = _UsageArgs, DisplayName = DisplayName, _pluginTag = PluginTag,
        _lowerAliases = LowerAliases, _lowerOriginal = LowerOriginal,
        Execute = function(...)
            local s, e = pcall(Function, ...)
            if not s then
                warn(`[CMD ERROR] {ActualName}: {e}`)
            end
        end
	}

	for _, Alias in next, _Aliases do
		LowerAliases[#LowerAliases + 1] = string.lower(Alias)
	end

	CommandListData[LowerOriginal] = entry

	for _, Alias in next, LowerAliases do
        CommandListData[Alias] = entry
    end

	CommandListArray[#CommandListArray + 1] = entry

	local HasBool = false
	for _, Argument in next, _UsageArgs do
        local Lowered = string.lower(Argument)
		if Lowered:find("true") or Lowered:find("false") then
            HasBool = true
            break
        end
	end

	if HasBool and not ActualName:match("^un") then
		PendingUNCommands[#PendingUNCommands + 1] = {
            name = ActualName, func = Function
        }
	end
end

local function ResolveUNCommands()
	for _, p in next, PendingUNCommands do
		local unName = `un{p.name}`
        if CommandListData[unName] then continue end

        local unEntry: Command = {
            Original = unName, Description = "Disable " .. p.name,
            Aliases = {}, UsageArgs = {}, DisplayName = unName,
            _lowerOriginal = unName, _lowerAliases = {},
            Execute = function()
                local ok, err = pcall(p.func, "false")
                if not ok then warn("[CMD ERROR] " .. unName .. ": " .. tostring(err)) end
            end
        }

        CommandListData[unName] = unEntry
        CommandListArray[#CommandListArray + 1] = unEntry
	end
end

local function ExecuteCommand(cmdName, ...)
	local cmd = CommandListData[string.lower(cmdName)]
	if cmd then cmd.Execute(...) end
