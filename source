local function RandomString(len: number?, charset: string?)
    local _len = len or math.random(10, 20)
    local buff = buffer.create(_len)
    local _charset = charset or "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local clen = #_charset
    for i = 1, _len do
        local c = string.byte(_charset, math.random(1, clen))
        buffer.writeu8(buff, i - 1, c)
    end
    return buffer.tostring(buff)
end

