		for _, f in next, item.p.files or {} do
			if f.filename:match("%.iy$") then
				local url = HttpService:UrlEncode("https://iyplugins.pages.dev/" .. f.url)
				local tracker = "https://iy-analytics.renern.workers.dev/load/"
					.. item.p.id .. "?url=" .. url
