local function coordsfix(a, b, c)
	if a and not b and not c then
		local nums = {}
		for v in tostring(a):gmatch("[-%d%.]+") do nums[#nums + 1] = tonumber(v) end
		return nums[1], nums[2], nums[3]
	end
	return tonumber(a), tonumber(b), tonumber(c)
end

