local function stripPluginCmds(pluginName)
	local newArray = {}
	for _, entry in next, CommandListArray do
		if entry._pluginTag ~= pluginName then
			table.insert(newArray, entry)
		else
			CommandListData[entry._lowerOriginal] = nil
			for _, alias in next, entry._lowerAliases do
				CommandListData[alias] = nil
			end
		end
	end
	CommandListArray = newArray
end

local function removePlugin(args)
	local NAME = args.name or args[1]
	if not NAME or NAME == "" then
        Unexpected:notify("unexpected", "Usage: unplugin [name]")
        return
    end
	if CONFIG.Plugins[NAME] then
		CONFIG.Plugins[NAME] = nil
		stripPluginCmds(NAME)
		UX_config()
		Unexpected:notify("unexpected", "Plugin '" .. NAME .. "' disabled.")
		if MENUFRAMES.plugin.Visible then renderList("plugin") end
		if MENUFRAMES.command.Visible then
			ClearCommandList()
			showcmdList()
