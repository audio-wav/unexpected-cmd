local _fadeTargets = setmetatable({} :: {[Frame]: {TextLabel | TextButton | TextBox | ImageLabel | ImageButton}}, { __mode = "k" })
local function GetFadeTargets(frame: Frame): {TextLabel | TextButton | TextBox | ImageLabel | ImageButton}
    local t = _fadeTargets[frame]
    if t then return t end
    t = frame:QueryDescendants("TextLabel,TextButton,TextBox,ImageLabel,ImageButton") :: any
    _fadeTargets[frame] = t
    return t
end

local function CreateTween(
    Object: Instance, Properties: {[string]: any},
    Time: number?, EasingStyle: Enum.EasingStyle?
)
	return TweenService:Create(Object, TweenInfo.new(Time or 0.2, EasingStyle or Enum.EasingStyle.Sine), Properties)
end

local function ButtonTween(button: GuiButton?, target: number?): ()
	local prop = button:IsA("ImageButton") and "ImageTransparency" or "TextTransparency"
	CreateTween(button, { [prop] = target }, 0.2, Enum.EasingStyle.Sine):Play()
end

local function FadeIn(frame: Frame?): ()
	frame.Visible = true
	local targets = GetFadeTargets(frame)
	for _, c in next, targets do
		if c:IsA("TextLabel") or c:IsA("TextButton") or c:IsA("TextBox") then
			c.TextTransparency = 1
			CreateTween(c, { TextTransparency = 0 }):Play()
		elseif c:IsA("ImageLabel") or c:IsA("ImageButton") then
			c.ImageTransparency = 1
			CreateTween(c, { ImageTransparency = 0 }):Play()
		end
	end
end

local function FadeOut(frame: Frame?): ()
	local targets = GetFadeTargets(frame)
	for _, c in next, targets do
		if c:IsA("TextLabel") or c:IsA("TextButton") or c:IsA("TextBox") then
			CreateTween(c, { TextTransparency = 1 }):Play()
		elseif c:IsA("ImageLabel") or c:IsA("ImageButton") then
			CreateTween(c, { ImageTransparency = 1 }):Play()
		end
	end
	task.delay(0.2, function() frame.Visible = false end)
end


local function RandomString(len: number?, charset: string?): string
    local _len = len or math.random(10, 20)
    local buff = buffer.create(_len)
    local _charset = charset or "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local clen = #_charset
    for i = 1, _len do
        local c = string.byte(_charset, math.random(1, clen))
        buffer.writeu8(buff, i - 1, c)
    end
    return buffer.tostring(buff)
end

