local activeEventConns = {}
local function runCmd(full)
	local cmdName, argsText = string.match(full, "^(%S+)%s*(.*)$")
	if not cmdName then return end
	local cmd = commandListData[string.lower(cmdName)]
	if cmd then
		local args = {}
		for arg in string.gmatch(argsText, "%S+") do table.insert(args, arg) end
		pcall(cmd.Execute, table.unpack(args))
	end
end

local function disconnectEvents()
	for _, c in ipairs(activeEventConns) do pcall(function() c:Disconnect() end) end
	activeEventConns = {}
end

local function hookEvents()
	disconnectEvents()
	CONFIG.Events = CONFIG.Events or {}
	for _, ev in ipairs(CONFIG.Events) do
		local event, filter, cmd = ev.event, ev.filter, ev.cmd
		local conn
		if event == "died" then
			conn = HUM.Died:Connect(function() runCmd(cmd) end)
		elseif event == "respawned" then
			conn = LP.CharacterAdded:Connect(function() task.wait(0.5) runCmd(cmd) end)
		elseif event == "jumped" then
			conn = HUM.Jumping:Connect(function(active) if active then runCmd(cmd) end end)
		elseif event == "seated" then
			conn = HUM.Seated:Connect(function(active) if active then runCmd(cmd) end end)
		elseif event == "statechanged" then
			conn = HUM.StateChanged:Connect(function(_, new)
				if not filter or new.Name:lower() == filter:lower() then runCmd(cmd) end
			end)
		elseif event == "healthchanged" then
			conn = HUM.HealthChanged:Connect(function() runCmd(cmd) end)
		elseif event == "fallendamage" then
			local last = HUM.Health
			conn = HUM.HealthChanged:Connect(function(hp)
				if hp < last and HUM:GetState() == Enum.HumanoidStateType.Freefall then runCmd(cmd) end
				last = hp
			end)
		elseif event == "playerjoined" then
			conn = PLRS.PlayerAdded:Connect(function(p)
				if not filter or filter == "any" or p.Name:lower() == filter:lower() or p.DisplayName:lower() == filter:lower() then
					runCmd(cmd)
				end
			end)
		elseif event == "playerleft" then
			conn = PLRS.PlayerRemoving:Connect(function(p)
				if not filter or filter == "any" or p.Name:lower() == filter:lower() or p.DisplayName:lower() == filter:lower() then
					runCmd(cmd)
				end
			end)
		elseif event == "chatted" then
			conn = PLRS.PlayerAdded:Connect(function() end)
			for _, p in ipairs(PLRS:GetPlayers()) do
				local c = p.Chatted:Connect(function(msg)
					if not filter or filter == "any" or msg:lower():find(filter:lower(), 1, true) then
						runCmd(cmd)
					end
				end)
				table.insert(activeEventConns, c)
			end
			PLRS.PlayerAdded:Connect(function(p)
				local c = p.Chatted:Connect(function(msg)
					if not filter or filter == "any" or msg:lower():find(filter:lower(), 1, true) then
						runCmd(cmd)
					end
				end)
				table.insert(activeEventConns, c)
			end)
		elseif event == "keypressed" then
			conn = UIS.InputBegan:Connect(function(input, processed)
				if processed then return end
				if filter and input.KeyCode.Name:lower() == filter:lower() then runCmd(cmd) end
			end)
		elseif event == "keyreleased" then
			conn = UIS.InputEnded:Connect(function(input)
				if filter and input.KeyCode.Name:lower() == filter:lower() then runCmd(cmd) end
			end)
		elseif event == "clicked" then
			conn = UIS.InputBegan:Connect(function(input, processed)
				if processed then return end
				if input.UserInputType == Enum.UserInputType.MouseButton1 then runCmd(cmd) end
			end)
		elseif event == "touched" then
			conn = HRP.Touched:Connect(function(part)
				if not filter or part.Name:lower() == filter:lower() then runCmd(cmd) end
			end)
		elseif event == "equipped" then
			conn = CHAR and CHAR.ChildAdded:Connect(function(c)
				if c:IsA("Tool") then
					if not filter or c.Name:lower() == filter:lower() then runCmd(cmd) end
				end
			end)
		elseif event == "unequipped" then
			conn = CHAR and CHAR.ChildRemoved:Connect(function(c)
				if c:IsA("Tool") then
					if not filter or c.Name:lower() == filter:lower() then runCmd(cmd) end
				end
			end)
		elseif event == "teleported" then
			conn = LP.OnTeleport:Connect(function(state)
				if state == Enum.TeleportState.Started then runCmd(cmd) end
			end)
		elseif event == "zoomchanged" then
			conn = CAM:GetPropertyChangedSignal("CameraDistance"):Connect(function() runCmd(cmd) end)
		end
		if conn then table.insert(activeEventConns, conn) end
	end
end

