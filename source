local waypointVisuals = {}
local function cWPVisual(name, pos)
	local part = Instance.new("Part")
	part.Name = "UXWP_" .. name
	part.Size = Vector3.new(5, 5, 5)
	part.CFrame = CFrame.new(pos)
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 1
	part.Parent = WS
	
	local adornment = Instance.new("BoxHandleAdornment")
	adornment.Adornee = part
	adornment.AlwaysOnTop = true
	adornment.ZIndex = 10
	adornment.Size = part.Size
	adornment.Color3 = Color3.fromRGB(0, 255, 0)
	adornment.Transparency = 0.3
	adornment.Parent = part
	
	waypointVisuals[name] = part
	return part
end

local function dWPVisual(name)
	if waypointVisuals[name] then
		pcall(function() waypointVisuals[name]:Destroy() end)
		waypointVisuals[name] = nil
	end
end

