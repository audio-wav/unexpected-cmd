local activeEventConns = {}
local function runCmd(full)
	local cmdName, argsText = string.match(full, "^(%S+)%s*(.*)$")
	if not cmdName then return end
	local cmd = CommandListData[string.lower(cmdName)]
	if cmd then
		local args = {}
		for arg in string.gmatch(argsText, "%S+") do table.insert(args, arg) end
		pcall(cmd.Execute, table.unpack(args))
	end
end

local function disconnectEvents()
	for _, c in next, activeEventConns do
        c:Disconnect()
    end
	activeEventConns = {}
end

local function hookEvents()
	disconnectEvents()
	CONFIG.Events = CONFIG.Events or {}
	if LocalPlayer.Character then
		Humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid") or Humanoid
		RootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or RootPart
	end
	local function matches(filter, val)
		return not filter or filter == "any" or tostring(val):lower():find(filter:lower(), 1, true)
	end
	local EVENT_MAP = {
		died = function(ev) return Humanoid.Died:Connect(function() runCmd(ev.cmd) end) end,
		respawned = function(ev)
            return LocalPlayer.CharacterAdded:Connect(function()
                task.wait(0.5)
                runCmd(ev.cmd)
            end)
        end,
		jumped = function(ev) return Humanoid.Jumping:Connect(function(a) if a then runCmd(ev.cmd) end end) end,
		seated = function(ev) return Humanoid.Seated:Connect(function(a) if a then runCmd(ev.cmd) end end) end,
		healthchanged = function(ev) return Humanoid.HealthChanged:Connect(function() runCmd(ev.cmd) end) end,
		statechanged = function(ev)
			return Humanoid.StateChanged:Connect(function(_, new)
				if matches(ev.filter, new.Name) then runCmd(ev.cmd) end
			end)
		end,
		fallendamage = function(ev)
			local last = Humanoid.Health
			return Humanoid.HealthChanged:Connect(function(hp)
				if hp < last and Humanoid:GetState() == Enum.HumanoidStateType.Freefall then runCmd(ev.cmd) end
				last = hp
			end)
		end,
		playerjoined = function(ev)
			return Players.PlayerAdded:Connect(function(p)
				if matches(ev.filter, p.Name) or matches(ev.filter, p.DisplayName) then runCmd(ev.cmd) end
			end)
		end,
		playerleft = function(ev)
			return Players.PlayerRemoving:Connect(function(p)
				if matches(ev.filter, p.Name) or matches(ev.filter, p.DisplayName) then runCmd(ev.cmd) end
			end)
		end,
		chatted = function(ev)
			local function hookPlayer(p)
				local c = p.Chatted:Connect(function(msg)
					if matches(ev.filter, msg) then runCmd(ev.cmd) end
				end)
				table.insert(activeEventConns, c)
			end
			for _, p in next, Players:GetPlayers() do hookPlayer(p) end
			return Players.PlayerAdded:Connect(hookPlayer)
		end,
		keypressed = function(ev)
			return UserInputService.InputBegan:Connect(function(input, processed)
				if not processed and matches(ev.filter, input.KeyCode.Name) then runCmd(ev.cmd) end
			end)
		end,
		keyreleased = function(ev)
			return UserInputService.InputEnded:Connect(function(input)
				if matches(ev.filter, input.KeyCode.Name) then runCmd(ev.cmd) end
			end)
		end,
		clicked = function(ev)
			return UserInputService.InputBegan:Connect(function(input, processed)
				if not processed and input.UserInputType == Enum.UserInputType.MouseButton1 then runCmd(ev.cmd) end
			end)
		end,
		touched = function(ev)
			return RootPart.Touched:Connect(function(part)
				if matches(ev.filter, part.Name) then runCmd(ev.cmd) end
			end)
		end,
		equipped = function(ev)
			return Character and Character.ChildAdded:Connect(function(c)
				if c:IsA("Tool") and matches(ev.filter, c.Name) then runCmd(ev.cmd) end
			end)
		end,
		unequipped = function(ev)
			return Character and Character.ChildRemoved:Connect(function(c)
				if c:IsA("Tool") and matches(ev.filter, c.Name) then runCmd(ev.cmd) end
			end)
		end,
		teleported = function(ev)
			return LocalPlayer.OnTeleport:Connect(function(state)
				if state == Enum.TeleportState.Started then runCmd(ev.cmd) end
			end)
		end,
		zoomchanged = function(ev)
			return Camera:GetPropertyChangedSignal("CameraDistance"):Connect(function() runCmd(ev.cmd) end)
		end,
	}
	for _, ev in next, CONFIG.Events do
		local handler = EVENT_MAP[ev.event]
		if handler then
			local ok, conn = pcall(handler, ev)
			if ok and conn then table.insert(activeEventConns, conn) end
		else
			Unexpected:notify("events", "unknown event: " .. tostring(ev.event))
		end
	end
end

