local Keybinds = {}
local BindConnections = {}
local BindToggleStates = {}
local bindIdCounter = 0

local function mkBINDID()
	bindIdCounter = bindIdCounter + 1
	return "bind_" .. bindIdCounter
end

local function mkKEYCONN(keyName)
	if BindConnections[keyName] then return end
	local conn = UserInputService.InputBegan:Connect(function(input, processed)
		if not processed and input.KeyCode.Name:lower() == keyName then
			local binds = Keybinds[keyName] or {}
			for _, bind in next, binds do
				if bind.fn then
					pcall(bind.fn)
				elseif bind.cmd then
					if bind.toggle then
						if BindToggleStates[bind.id] then
							BindToggleStates[bind.id] = false
							local cmdToRun = bind.cmd
							if cmdToRun:match("%s(true)$") then cmdToRun = cmdToRun:gsub("true$", "false")
							elseif cmdToRun:match("%s(false)$") then cmdToRun = cmdToRun:gsub("false$", "true")
							else
								local parts = {}
								for w in bind.cmd:gmatch("%S+") do parts[#parts+1] = w end
								cmdToRun = "un" .. (parts[1] or "") -- fix nesting
							end
							runCmd(cmdToRun)
						else
							BindToggleStates[bind.id] = true
							runCmd(bind.cmd)
						end
					else
						runCmd(bind.cmd)
					end
				end
			end
		end
	end)
	BindConnections[keyName] = conn
end

local function UX_addbind(keyName, cmdString, toggle)
	keyName = keyName:lower()
	if not Keybinds[keyName] then Keybinds[keyName] = {} end
	local bindId = mkBINDID()
	if toggle then BindToggleStates[bindId] = false end
	table.insert(Keybinds[keyName], { id = bindId, cmd = cmdString, toggle = toggle or false, fn = nil })
	mkKEYCONN(keyName)
end

local function UX_addPluginBind(keyName, fn)
	keyName = keyName:lower()
	if not Keybinds[keyName] then Keybinds[keyName] = {} end
	local bindId = mkBINDID()
	table.insert(Keybinds[keyName], { id = bindId, cmd = nil, toggle = false, fn = fn, isPlugin = true })
	mkKEYCONN(keyName)
end

local function UX_unbind(keyName, bindId)
	keyName = keyName:lower()
	if not Keybinds[keyName] then return end
	if bindId then
		for i, bind in next, Keybinds[keyName] do
			if bind.id == bindId then
				table.remove(Keybinds[keyName], i)
				BindToggleStates[bindId] = nil
				break
			end
		end
	else
		Keybinds[keyName] = {}
	end
	if #(Keybinds[keyName] or {}) == 0 then
		if BindConnections[keyName] then
			BindConnections[keyName]:Disconnect()
			BindConnections[keyName] = nil
		end
		Keybinds[keyName] = nil
	end
end

local function migrateBinds()
	CONFIG.Binds = CONFIG.Binds or {}
	for i, bd in next, CONFIG.Binds do
        if bd.id then continue end
        bd.id = mkBINDID()
        bd.isPlugin = bd.isPlugin or false
	end
	UX_config()
end

local function mkPLUGINENV()
	local _args = {}
	local function getString(idx)
		if #_args < idx then return "" end
		local t = {}
		for i = idx, #_args do t[#t+1] = _args[i] end
		return table.concat(t, " ")
	end
	local function getPlayer(arg, spk)
		if not arg or arg == "" then return {} end
		arg = arg:lower()
		local results = {}
		if arg == "all" then
			for _, p in next, Players:GetPlayers() do
                results[#results+1] = p.Name
            end
		elseif arg == "others" then
			for _, p in next, Players:GetPlayers() do
				if p ~= LocalPlayer then results[#results+1] = p.Name end
			end
		elseif arg == "me" then
			results[#results+1] = LocalPlayer.Name
		elseif arg:sub(1,1) == "%" then
			local teamName = arg:sub(2)
			for _, p in next, Players:GetPlayers() do
				if p.Team and p.Team.Name:lower():find(teamName, 1, true) then results[#results+1] = p.Name end
			end
		else
			for _, p in next, Players:GetPlayers() do
				if p.Name:lower():sub(1, #arg) == arg or p.DisplayName:lower():sub(1, #arg) == arg then
					results[#results+1] = p.Name
                    break
				end
			end
		end
		return results
	end
	local function getRoot(char)
		return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char.PrimaryPart)
	end
	return {
		_args = _args,
		args = _args,
		getstring = getString,
		getPlayer = getPlayer,
		getRoot = getRoot,
		parseBoolean = function(str)
			if not str then return nil end
			str = str:lower()
			if str=="true" or str=="yes" or str=="on" or str=="1" then return true end
			if str=="false" or str=="no" or str=="off" or str=="0" then return false end
			return nil
		end,
		notify = function(title, text) Unexpected:notify(tostring(title), tostring(text or "")) end,
		randomString = RandomString,
		splitString = function(sep, str)
			local t = {}
			for s in str:gmatch("[^"..sep.."]+") do t[#t+1] = s end
			return t
		end,
		toClipboard = function(str) setclipboard(tostring(str)) end,
		Time = function() return os.time() end,
		FindInTable = function(t, val)
			for i,v in next, t do
                if v == val then return i end
            end
			return false
		end,
		GetInTable = function(t, key) return t[key] end,
		writefileExploit = function(path, content) if writefile then pcall(writefile, path, content) end end,
		isNumber = function(str) return tonumber(str) ~= nil end,
		tools = function()
			local t = {}
			for _, v in next, LocalPlayer.Backpack:GetChildren() do
                if v:IsA("Tool") then t[#t+1] = v end
            end
			for _, v in next, Character:GetChildren() do
                if v:IsA("Tool") then t[#t+1] = v end
            end
			return t
		end,
		r15 = function() return Character and Character:FindFirstChild("UpperTorso") ~= nil end,
		Match = function(str, pat) return str:match(pat) end,
		respawn = function() LocalPlayer:LoadCharacter() end,
		refresh = function() LocalPlayer:LoadCharacter() end,
		execCmd = ExecuteCommand,
		addbind = function(key, fn)
			UX_addPluginBind((typeof(key) == "EnumItem" and key.Name or tostring(key)):lower(), fn)
		end,
		addspawn = function(fn) LocalPlayer.CharacterAdded:Connect(fn) end,
		round = function(num, places)
			local m = 10^(places or 0)
			return math.floor(num*m+0.5)/m
		end,
		ESP = function() end,
		CHMS = function() end,
		unkeybind = function(key)
			UX_unbind((typeof(key) == "EnumItem" and key.Name or tostring(key)):lower())
		end,
		speaker = LocalPlayer,
		Players = Players,
		Player = LocalPlayer,
		Character = Character,
		Humanoid = Humanoid,
		RootPart = RootPart,
		Camera = Camera,
		workspace = Workspace,
		Workspace = Workspace,
		game = game,
		wait = task.wait,
		spawn = task.spawn,
		delay = task.delay,
		cloneref = cloneref,
		sethiddenproperty = typeof(sethiddenproperty) == "function" and sethiddenproperty or nil,
		setfflag = typeof(setfflag) == "function" and setfflag or nil,
		unexpected = Unexpected,
	}, _args
end

local function loadPlugin(name, source, isIY)
	if isIY then
		local Environment = setmetatable(mkPLUGINENV(), { __index = getfenv() })
		local s, Result = pcall(function()
            return assert(setfenv(
                assert(loadstring(source), "Syntax Error"), Environment
            ), "setfenv Fail")()
        end)
		if not s then
			Unexpected:notify("unexpected", ("Plugin '%s' error: %s"):format(name, tostring(Result)))
			return false
		end
		if type(Result) ~= "table" then
			Unexpected:notify("unexpected", ("Plugin '%s' returned non-table"):format(name))
			return false
		end
		local pluginName = Result.PluginName or name
		local cmds = Result.Commands
		if type(cmds) ~= "table" then
			Unexpected:notify("unexpected", ("Plugin '%s' has no Commands table"):format(name))
			return false
		end
		local count = 0
		for cmdKey, cmdDef in next, cmds do
			if type(cmdDef) == "table" and type(cmdDef.Function) == "function" then
				local listName = cmdDef.ListName or cmdKey
				local usageArgs = {}
				for arg in listName:gmatch("%[(.-)%]") do usageArgs[#usageArgs+1] = arg end
				local displayBase = (listName:gsub("%s*%[.-%]", ""):match("^%s*([^/]+)%s*") or listName):match("^%s*(.-)%s*$")
				local aliases = {}
				if type(cmdDef.Aliases) == "table" then
					for _, a in next, cmdDef.Aliases do
						if a ~= cmdKey then aliases[#aliases+1] = a end
					end
				end
				local fn = cmdDef.Function
				local pluginENV, argRef = mkPLUGINENV()
				setfenv(fn, setmetatable(pluginENV, { __index = getfenv() }))
				Unexpected:AddCommand(displayBase, cmdDef.Description or "No description.", function(...)
					local args = {...}
					table.clear(argRef)
					for i, v in next, args do
                        argRef[i] = v
                    end
					pcall(fn, args, LocalPlayer)
				end, aliases, usageArgs, name)
				count = count + 1
			end
		end
		Unexpected:notify("unexpected", ("%s loaded (%d cmd%s)"):format(pluginName, count, count==1 and "" or "s"))
		return true
	else
		local Environment = setmetatable(mkPLUGINENV(), { __index = getfenv() })
		local s, Result = pcall(function()
            return assert(setfenv(
                assert(loadstring(source), "Syntax Error"), Environment
            ), "setfenv Fail")()
        end)
		if not s then
			Unexpected:notify("unexpected", ("Error in plugin '%s': %s"):format(name, tostring(Result)))
			return false
		end
		if type(Result) == "table" and Result.Commands then
			for CMD_NAME, CMD in next, Result.Commands do
				if type(CMD.Function) == "function" then
					Unexpected:AddCommand(CMD.ListName or CMD_NAME, CMD.Description or "No description.", CMD.Function, CMD.Aliases or {}, CMD.Args or {}, name)
				end
			end
		end
		Unexpected:notify("unexpected", "Loaded plugin: " .. (Result and Result.PluginName or name))
		return true
	end
end

local function LOAD_PLUGIN(NAME)
    local UX_PATH = ("%s/%s.ux"):format(PLUGIN_DIR, NAME)
    local IY_PATH = ("%s/%s.iy"):format(PLUGIN_DIR, NAME)
    local IY_BARE = ("%s.iy"):format(NAME)
    local source, isIY
    if isfile(UX_PATH) then source, isIY = readfile(UX_PATH), false
    elseif isfile(IY_PATH) then source, isIY = readfile(IY_PATH), true
    elseif isfile(IY_BARE) then source, isIY = readfile(IY_BARE), true
    else
        Unexpected:notify("unexpected", ("Plugin '%s' not found (.ux/.iy), removed."):format(NAME))
        CONFIG.Plugins[NAME] = nil
        UX_config()
        return false
    end
    return loadPlugin(NAME, source, isIY)
end

