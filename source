local function LoadSettings(): ()
	if not isfile(Settings.ConfigFile) then return end
	local Success, Raw = pcall(readfile, Settings.ConfigFile)
	if not Success then return end
	local Success2, Data = pcall(function() return HttpService:JSONDecode(Raw) end)
	if not Success2 or type(Data) ~= "table" then return end

	Settings.KeepUX = Data.KeepUX ~= nil and Data.KeepUX or Settings.KeepUX
	Settings.StatsSent = Data.StatsSent
	Settings.Plugins = Data.Plugins or {}
	Settings.Autoruns = Data.Autoruns or {}
	Settings.Binds = Data.Binds or {}
	Settings.Waypoints = Data.Waypoints or {}
	Settings.Events = Data.Events or {}

	if type(Data.Prefix) == "string" then
		Settings.Prefix = Enum.KeyCode[Data.Prefix] or Enum.KeyCode.Semicolon
	end

	if type(Data.UI) == "table" then
		for k, v in next, Data.UI do Settings.Ui[k] = v end
	end

	if type(Data.Theme) == "table" then
		local t = Data.Theme
		if t.Background then Settings.Theme.Background = Color3.fromRGB(t.Background[1], t.Background[2], t.Background[3]) end
		if t.Stroke then Settings.Theme.Stroke = Color3.fromRGB(t.Stroke[1], t.Stroke[2], t.Stroke[3]) end
		if t.TextMain then Settings.Theme.TextMain = Color3.fromRGB(t.TextMain[1], t.TextMain[2], t.TextMain[3]) end
		if t.TextDim then Settings.Theme.TextDim = Color3.fromRGB(t.TextDim[1], t.TextDim[2], t.TextDim[3]) end
		if t.Accent then Settings.Theme.Accent = Color3.fromRGB(t.Accent[1], t.Accent[2], t.Accent[3]) end
	end
end

local function SaveSettings(): ()
	local Serialized = table.clone(Settings)
	Serialized.Prefix = Settings.Prefix.Name
	Serialized.Theme = {
		Background = {Settings.Theme.Background.R*255, Settings.Theme.Background.G*255, Settings.Theme.Background.B*255},
		Stroke = {Settings.Theme.Stroke.R*255, Settings.Theme.Stroke.G*255, Settings.Theme.Stroke.B*255},
		TextMain = {Settings.Theme.TextMain.R*255, Settings.Theme.TextMain.G*255, Settings.Theme.TextMain.B*255},
		TextDim = {Settings.Theme.TextDim.R*255, Settings.Theme.TextDim.G*255, Settings.Theme.TextDim.B*255},
		Accent = {Settings.Theme.Accent.R*255, Settings.Theme.Accent.G*255, Settings.Theme.Accent.B*255},
	}
	Serialized.UI = table.clone(Settings.Ui)
	pcall(writefile, Settings.ConfigFile, HttpService:JSONEncode(Serialized))
end

