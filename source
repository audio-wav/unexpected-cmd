local List = {
	actions = {}, renderers = {}, filters = {}
}

function List.register(listKey, fn)
	List.actions[listKey] = fn
end

local function renderList(key)
	local fn = List.renderers[key]
	if fn then fn() end
end

local function mkListSystem(listKey, btnList, btnExample, getItems)
	List.renderers[listKey] = function()
		_fadeTargets[btnList.Parent] = nil
		local filter = (List.filters[listKey] or ""):lower()
		for _, c in next, btnList:GetChildren() do if c:IsA("GuiButton") then c:Destroy() end end
		
		local items = getItems() or {}
		local filteredItems = {}
		for i, item in next, items do
			local text = item and item.text
			if text and (filter == "" or text:lower():find(filter, 1, true)) then
				table.insert(filteredItems, {item = item, index = i})
			end
		end
		
		local y = 0
		local index = 1
		local function renderBatch()
			local batchSize = 15
			local endIndex = math.min(index + batchSize - 1, #filteredItems)
			for i = index, endIndex do
				local entry = filteredItems[i]
				local item = entry.item
				local btn = btnExample:Clone()
				btn.Text, btn.Visible = item.text, true
				btn.Position = UDim2.new(0, 0, 0, y)
				btn.Parent = btnList
				y += 32
				btn.MouseButton1Click:Connect(function()
					local h = List.actions[listKey]
					if h then h(item, entry.index) else warn("No handler for:", listKey) end
				end)
			end
			index = endIndex + 1
			if index <= #filteredItems then
				task.defer(renderBatch)
			else
				btnList.CanvasSize = UDim2.new(0, 0, 0, y)
				if applyColors then applyColors() end
			end
		end
		renderBatch()
	end
end

